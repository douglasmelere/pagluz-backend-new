# Database
DATABASE_URL="postgresql://username:password@localhost:5432/energy_management?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Application
PORT=3000
NODE_ENV="production"

# Para deploy no EasyPanel, configure estas variáveis:
# DATABASE_URL - URL de conexão com PostgreSQL
# JWT_SECRET - Chave secreta para JWT (gere uma chave forte)
# PORT - Porta da aplicação (geralmente 3000)
# NODE_ENV - Ambiente (production)

